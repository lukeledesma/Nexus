<%# locals: window_key, pin_key, label, icon %>
<%# Wrapper div avoids nested <button> (pin + launch), which breaks the DOM in browsers. %>
<div class="launcher-tile-wrap">
  <button
    type="button"
    class="os-window-card os-window-card--launcher-tile launcher-tile-main"
    data-window-key="<%= window_key %>"
    data-action="click->organizer#launchApp"
    aria-pressed="false"
  >
    <dl class="os-window-card-content launcher-tile-body">
      <dt class="os-window-card-label"><%= label %></dt>
      <dd class="os-window-card-value os-window-card-value--icon launcher-card-icon" aria-hidden="true"><%= material_symbol_icon(icon, size: :lg) %></dd>
    </dl>
  </button>
  <%= render "organizer/launcher_dock_pin_button", app_key: pin_key %>
</div>
