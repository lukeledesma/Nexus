<section id="organizer" class="organizer-panel" data-controller="organizer" data-finder-target="sidebar">
  <header class="organizer-panel-header" data-action="mousedown->window-manager#startDrag touchstart->window-manager#startDrag">
    <h2>TOOLS</h2>
    <div class="organizer-panel-controls">
      <button type="button" class="tools-close-btn tools-close-btn--organizer" data-action="click->window-manager#closeTools" aria-label="Close TOOLS" title="Close">✕</button>
    </div>
  </header>

  <p class="organizer-panel-stamp" data-organizer-target="stamp">No recent updates yet</p>

  <nav class="organizer-tools-grid" aria-label="Tools">
    <button
      type="button"
      class="finder-item"
      data-finder-target="item"
      data-app-id="singular_note"
      data-action="click->finder#toggle"
    >
      <div class="organizer-tool-card">
        <dt class="organizer-tool-label">NOTES</dt>
        <dd class="organizer-tool-value" data-organizer-target="notesSize">-</dd>
      </div>
    </button>

    <button
      type="button"
      class="finder-item"
      data-finder-target="item"
      data-app-id="singular_task_list"
      data-action="click->finder#toggle"
    >
      <div class="organizer-tool-card">
        <dt class="organizer-tool-label">TASKS</dt>
        <dd class="organizer-tool-value" data-organizer-target="tasksSize">-</dd>
      </div>
    </button>

    <button
      type="button"
      class="finder-item"
      data-finder-target="item"
      data-app-id="conversion_chart"
      data-action="click->finder#toggle"
    >
      <div class="organizer-tool-card">
        <dt class="organizer-tool-label">SAE/METRIC</dt>
        <dd class="organizer-tool-value" data-organizer-target="conversionPair">—</dd>
      </div>
    </button>
  </nav>
</section>