<section class="app-surface app-surface--tool theme-builder-view" data-controller="theme-builder">
  <div class="theme-builder-main-shell os-window-body-start">

  <section class="theme-builder-section is-collapsed">
    <button
      type="button"
      class="theme-builder-section-title"
      data-action="click->theme-builder#toggleSection"
      aria-expanded="false"
    >SHELL</button>

    <div class="theme-builder-section-body">

    <label class="settings-interface-label" for="theme-builder-window-hue">H</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-window-hue"
        type="range"
        min="0"
        max="360"
        step="1"
        value="180"
        class="settings-interface-slider settings-interface-slider--hue"
        data-theme-builder-target="hueSlider"
        data-action="input->theme-builder#updateHue"
        aria-label="Window hue"
      >
      <output class="settings-interface-value" data-theme-builder-target="hueValue">180°</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-window-saturation">S</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-window-saturation"
        type="range"
        min="0"
        max="100"
        step="1"
        value="0"
        class="settings-interface-slider settings-interface-slider--saturation"
        data-theme-builder-target="saturationSlider"
        data-action="input->theme-builder#updateSaturation"
        aria-label="Window saturation"
      >
      <output class="settings-interface-value" data-theme-builder-target="saturationValue">0%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-window-brightness">B</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-window-brightness"
        type="range"
        min="0"
        max="100"
        step="1"
        value="15"
        class="settings-interface-slider settings-interface-slider--brightness"
        data-theme-builder-target="brightnessSlider"
        data-action="input->theme-builder#updateBrightness"
        aria-label="Window brightness"
      >
      <output class="settings-interface-value" data-theme-builder-target="brightnessValue">15%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-window-transparency">T</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-window-transparency"
        type="range"
        min="15"
        max="95"
        step="1"
        value="15"
        class="settings-interface-slider settings-interface-slider--alpha"
        data-theme-builder-target="transparencySlider"
        data-action="input->theme-builder#updateTransparency"
        aria-label="Window transparency"
      >
      <output class="settings-interface-value" data-theme-builder-target="transparencyValue">15%</output>
    </div>
    </div>
  </section>

  <section class="theme-builder-section is-collapsed">
    <button
      type="button"
      class="theme-builder-section-title"
      data-action="click->theme-builder#toggleSection"
      aria-expanded="false"
    >BACKGROUND</button>

    <div class="theme-builder-section-body">

    <label class="settings-interface-label" for="theme-builder-bg-1-hue">H1</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-1-hue"
        type="range"
        min="0"
        max="360"
        step="1"
        value="240"
        class="settings-interface-slider settings-interface-slider--hue"
        data-theme-builder-target="bgOneHueSlider"
        data-action="input->theme-builder#updateBgOneHue"
        aria-label="Background color one hue"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgOneHueValue">240°</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-1-saturation">S1</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-1-saturation"
        type="range"
        min="0"
        max="100"
        step="1"
        value="28"
        class="settings-interface-slider settings-interface-slider--bg-1-saturation"
        data-theme-builder-target="bgOneSaturationSlider"
        data-action="input->theme-builder#updateBgOneSaturation"
        aria-label="Background color one saturation"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgOneSaturationValue">28%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-1-brightness">B1</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-1-brightness"
        type="range"
        min="0"
        max="100"
        step="1"
        value="14"
        class="settings-interface-slider settings-interface-slider--bg-1-brightness"
        data-theme-builder-target="bgOneBrightnessSlider"
        data-action="input->theme-builder#updateBgOneBrightness"
        aria-label="Background color one brightness"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgOneBrightnessValue">14%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-2-hue">H2</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-2-hue"
        type="range"
        min="0"
        max="360"
        step="1"
        value="213"
        class="settings-interface-slider settings-interface-slider--hue"
        data-theme-builder-target="bgTwoHueSlider"
        data-action="input->theme-builder#updateBgTwoHue"
        aria-label="Background color two hue"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgTwoHueValue">213°</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-2-saturation">S2</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-2-saturation"
        type="range"
        min="0"
        max="100"
        step="1"
        value="73"
        class="settings-interface-slider settings-interface-slider--bg-2-saturation"
        data-theme-builder-target="bgTwoSaturationSlider"
        data-action="input->theme-builder#updateBgTwoSaturation"
        aria-label="Background color two saturation"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgTwoSaturationValue">73%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-2-brightness">B2</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-2-brightness"
        type="range"
        min="0"
        max="100"
        step="1"
        value="22"
        class="settings-interface-slider settings-interface-slider--bg-2-brightness"
        data-theme-builder-target="bgTwoBrightnessSlider"
        data-action="input->theme-builder#updateBgTwoBrightness"
        aria-label="Background color two brightness"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgTwoBrightnessValue">22%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-bg-angle">°</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-bg-angle"
        type="range"
        min="0"
        max="360"
        step="1"
        value="135"
        class="settings-interface-slider settings-interface-slider--bg-angle"
        data-theme-builder-target="bgAngleSlider"
        data-action="input->theme-builder#updateBgAngle"
        aria-label="Background gradient angle"
      >
      <output class="settings-interface-value" data-theme-builder-target="bgAngleValue">135°</output>
    </div>
    </div>
  </section>

  <section class="theme-builder-section is-collapsed">
    <button
      type="button"
      class="theme-builder-section-title"
      data-action="click->theme-builder#toggleSection"
      aria-expanded="false"
    >CONTENT</button>

    <div class="theme-builder-section-body">

    <label class="settings-interface-label" for="theme-builder-font-one">F1B</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-font-one"
        type="range"
        min="0"
        max="100"
        step="1"
        value="89"
        class="settings-interface-slider settings-interface-slider--mono"
        data-theme-builder-target="fontOneSlider"
        data-action="input->theme-builder#updateFontOne"
        aria-label="Primary text brightness"
      >
      <output class="settings-interface-value" data-theme-builder-target="fontOneValue">89%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-font-one-transparency">F1T</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-font-one-transparency"
        type="range"
        min="0"
        max="100"
        step="1"
        value="100"
        class="settings-interface-slider settings-interface-slider--mono"
        data-theme-builder-target="fontOneTransparencySlider"
        data-action="input->theme-builder#updateFontOneTransparency"
        aria-label="Primary text transparency"
      >
      <output class="settings-interface-value" data-theme-builder-target="fontOneTransparencyValue">100%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-font-two">F2B</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-font-two"
        type="range"
        min="0"
        max="100"
        step="1"
        value="63"
        class="settings-interface-slider settings-interface-slider--mono"
        data-theme-builder-target="fontTwoSlider"
        data-action="input->theme-builder#updateFontTwo"
        aria-label="Muted text brightness"
      >
      <output class="settings-interface-value" data-theme-builder-target="fontTwoValue">63%</output>
    </div>

    <label class="settings-interface-label" for="theme-builder-font-two-transparency">F2T</label>
    <div class="settings-interface-slider-row">
      <input
        id="theme-builder-font-two-transparency"
        type="range"
        min="0"
        max="100"
        step="1"
        value="100"
        class="settings-interface-slider settings-interface-slider--mono"
        data-theme-builder-target="fontTwoTransparencySlider"
        data-action="input->theme-builder#updateFontTwoTransparency"
        aria-label="Muted text transparency"
      >
      <output class="settings-interface-value" data-theme-builder-target="fontTwoTransparencyValue">100%</output>
    </div>

    </div>
  </section>
  </div>
</section>
