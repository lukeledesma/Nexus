<% frame_id = params[:frame_id].presence || "app-pane" %>
<turbo-frame id="<%= frame_id %>">
  <section class="app-surface app-surface--tool app-surface--whiteboard"
    data-controller="whiteboard"
    data-whiteboard-columns-value="75"
    data-whiteboard-rows-value="75"
    data-whiteboard-stickies-value="<%= json_escape(@stickies.to_json) %>"
    data-whiteboard-save-url-value="<%= apps_singular_whiteboard_path %>">
    <header class="app-surface-header tool-window-header os-window-header">
      <h2 class="tool-window-title os-window-title">WHITE BOARD</h2>
    </header>
    <p class="tool-window-subtitle os-window-subtitle">Blank space, ready for the next pass.</p>

    <div class="whiteboard-workspace os-window-body-start">
      <div class="whiteboard-content-shell app-content-shell" data-whiteboard-target="contentShell">
        <div class="whiteboard-grid" data-whiteboard-target="grid" aria-hidden="true"></div>
      </div>

      <div class="whiteboard-action-shell" aria-label="White board actions">
        <button type="button" class="whiteboard-action-btn" data-whiteboard-target="gridToggle" data-action="click->whiteboard#toggleGrid" aria-label="Toggle grid" aria-pressed="true" title="Toggle grid">⊞</button>
        <button type="button" class="whiteboard-action-btn" data-action="click->whiteboard#addSticky" aria-label="Add sticky note" title="Add sticky note">⧉</button>
        <div class="whiteboard-sticky-color-anchor">
          <button type="button" class="whiteboard-action-btn whiteboard-action-btn--sticky-indicator whiteboard-action-btn--hidden" data-whiteboard-target="stickySelection" data-action="click->whiteboard#toggleStickyColorPopover" aria-hidden="true" tabindex="-1" title="Sticky color">&nbsp;</button>
          <div class="whiteboard-sticky-color-popover whiteboard-action-btn--hidden" data-whiteboard-target="colorPopover" aria-hidden="true">
            <input type="range" class="whiteboard-sticky-color-slider settings-interface-slider settings-interface-slider--hue" data-whiteboard-target="colorSlider" data-action="input->whiteboard#updateStickyColor" min="0" max="360" step="1" value="45" aria-label="Sticky color slider">
          </div>
        </div>
      </div>
    </div>
  </section>
</turbo-frame>