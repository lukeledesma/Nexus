<% frame_id = params[:frame_id].presence || "app-pane" %>
<turbo-frame id="<%= frame_id %>">
  <section class="app-surface app-surface--tool app-surface--excalidraw"
    data-controller="excalidraw-canvas"
    data-excalidraw-canvas-initial-state-value="<%= json_escape(@drawing&.body.to_s) %>">
    <%= form_with model: @drawing,
      url: apps_singular_excalidraw_path(frame_id: frame_id),
      method: :patch,
      data: {
        turbo_frame: frame_id,
        controller: "autosave",
        autosave_item_id_value: @drawing.id,
        autosave_item_type_value: "excalidraw"
      },
      class: "excalidraw-form os-window-body-start",
      html: { autocomplete: "off" } do |f| %>
      <%= f.hidden_field :body, value: @drawing.body.to_s, name: "item[body]", data: { excalidraw_canvas_target: "stateInput" } %>
      <div class="excalidraw-container" data-excalidraw-canvas-target="container"></div>
    <% end %>
  </section>
</turbo-frame>
