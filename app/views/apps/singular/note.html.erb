<% frame_id = params[:frame_id].presence || "app-pane" %>
<turbo-frame id="<%= frame_id %>">
  <section class="app-surface app-surface--tool app-surface--quill-note"
    data-controller="quill-note"
    data-quill-note-initial-body-value="<%= @note&.body.to_s %>">
    <%= form_with model: @note,
      url: apps_singular_note_path(frame_id: frame_id),
      method: :patch,
      data: {
        turbo_frame: frame_id,
        controller: "autosave",
        autosave_item_id_value: @note.id,
        autosave_item_type_value: "note"
      },
      class: "quill-note-form os-window-body-start",
      html: { autocomplete: "off" } do |f| %>
      <%= f.hidden_field :body, value: @note.body.to_s, name: "item[body]", data: { quill_note_target: "bodyInput" } %>
      <div class="quill-note-editor-shell">
        <div class="quill-note-editor" data-quill-note-target="editor"></div>
      </div>
    <% end %>
  </section>
</turbo-frame>
