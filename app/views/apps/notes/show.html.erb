<turbo-frame id="app-pane">
  <section class="app-surface app-surface--note" data-controller="title-editor">
    <header class="app-surface-header">
      <h2 class="app-inline-title" data-action="click->title-editor#startEdit" title="Click to rename">
        <span data-title-editor-target="display"><%= @note.name %></span>
      </h2>
    </header>

    <%= form_with model: @note, url: apps_note_path(@note), method: :patch,
          data: {
            turbo_frame: "app-pane",
            controller: "autosave",
            autosave_item_id_value: @note.id,
            autosave_item_type_value: "note"
          },
          class: "note-form" do |f| %>
      <%= f.hidden_field :name, value: @note.name, name: "item[name]", data: { title_editor_target: "input" } %>
      <%= f.text_area :body, value: @note.body.to_s, name: "item[body]",
            class: "note-body-input", placeholder: "Start writing…" %>
    <% end %>
  </section>
</turbo-frame>
