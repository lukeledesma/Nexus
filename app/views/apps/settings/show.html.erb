<section class="app-surface">
  <header class="app-surface-header">
    <h2>Settings</h2>
    <p>System profile and finder preferences.</p>
  </header>

  <dl class="settings-grid">
    <div>
      <dt>Signed in as</dt>
      <dd><%= current_user.email %></dd>
    </div>
    <div>
      <dt>Theme</dt>
      <dd>Dark</dd>
    </div>
    <div>
      <dt>Finder mode</dt>
      <dd>Adaptive</dd>
    </div>
  </dl>
</section>
