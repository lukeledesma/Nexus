<div class="home" data-controller="folders">
  <header class="home-header">
    <h1 class="app-title">ALCHEMY<sup>5</sup></h1>
    <p class="tagline">Modbus tag editor — import XML, edit tags, export with preloads rebuilt.</p>
  </header>

  <div class="organizer-header mb-3">
    <button class="btn btn-primary" data-action="click->folders#createRootFolder">New Folder</button>
  </div>

  <div id="organizer-wrapper" data-controller="recent-docs">
    <div id="organizer-content">
      <%= render "organizer" %>
    </div>
  </div>
</div>
