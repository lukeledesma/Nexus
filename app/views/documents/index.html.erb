<div class="app-dock" id="app-dock" aria-label="Dock">
  <button
    type="button"
    class="app-dock-button app-dock-button--launcher"
    data-action="click->window-manager#toggleLauncher"
    data-hover-label="Launcher"
    aria-label="Open Launcher"
    aria-pressed="false"
  >
    <%= material_symbol_icon(:apps, size: :md) %>
  </button>
  <div class="app-dock-divider" id="app-dock-launcher-divider" role="separator" aria-hidden="true"></div>
  <div class="app-dock-group app-dock-group--pinned" id="app-dock-pinned"></div>
  <div class="app-dock-divider" id="app-dock-running-divider" role="separator" aria-hidden="true" hidden></div>
  <div class="app-dock-group app-dock-group--running" id="app-dock-running"></div>
</div>

<script type="application/json" id="nexus-dock-icon-html">
<%= raw({
  "finder" => material_symbol_icon(:folder, size: :md),
  "singular-note" => material_symbol_icon(:notepad, size: :md),
  "singular-task-list" => material_symbol_icon(:task_checklist, size: :md),
  "singular-sticky-notes" => material_symbol_icon(:sticky_note, size: :md),
  "settings" => material_symbol_icon(:settings, size: :md),
  "theme-studio" => material_symbol_icon(:tune, size: :md)
}.to_json) %>
</script>
