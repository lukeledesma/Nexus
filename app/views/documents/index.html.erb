<div class="app-dock" aria-label="Pinned apps">
  <button
    type="button"
    class="app-dock-button app-dock-button--db-health"
    data-action="click->window-manager#toggleDbHealth"
    data-hover-label="DB Health"
    aria-label="Open DB Health"
    aria-pressed="false"
  >
    ♥
  </button>

  <button
    type="button"
    class="app-dock-button app-dock-button--settings"
    data-action="click->window-manager#toggleSettings"
    data-hover-label="Settings"
    aria-label="Open Settings"
    aria-pressed="false"
  >
    ⚙
  </button>

  <button
    type="button"
    class="app-dock-button app-dock-button--stationary"
    data-action="click->window-manager#toggleStationary"
    data-hover-label="Stationary"
    aria-label="Open Stationary"
    aria-pressed="false"
  >
    ✎
  </button>

  <button
    type="button"
    class="app-dock-button app-dock-button--tools"
    data-action="click->window-manager#toggleTools"
    data-hover-label="Tools"
    aria-label="Open TOOLS"
    aria-pressed="false"
  >
    ⚒
  </button>
</div>
