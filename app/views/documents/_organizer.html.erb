<% if @has_organizer_content %>
  <section class="recent-docs organizer" data-controller="rename item-creator">
    <h2>Organizer</h2>

    <ul class="organizer-list">
      <% @browser_folders.each do |folder_entry| %>
        <% folder = folder_entry[:folder] %>
        <% files = folder_entry[:files] %>
        <% open_folder = flash[:created_file_id].present? && files.any? { |f| f[:document]&.id == flash[:created_file_id].to_i } %>
        <% row_classes = ["doc-row", "folder-item"] %>
        <% row_classes << "folder-row--created" if flash[:created_folder_id].to_i == folder&.id || flash[:created_folder_name] == folder_entry[:name] %>

        <li class="<%= row_classes.join(' ') %>" tabindex="0" data-recent-docs-target="doc" data-doc-kind="folder" data-folder-row="true" data-folder-id="<%= folder&.id %>" data-delete-url="<%= folder ? document_path(folder) : '' %>" data-expanded="<%= open_folder ? 'true' : 'false' %>">
          <% toggle_classes = ["organizer-row", "folder-toggle", "folder-row"] %>
          <% toggle_classes << "folder-row--expanded" if open_folder %>
          <% toggle_classes << (open_folder ? "folder-expanded" : "folder-collapsed") %>
          <div class="<%= toggle_classes.join(' ') %>" data-folder-name="<%= folder_entry[:title] %>" data-folder-toggle-row="true" data-type="folder" data-action="click->recent-docs#toggleFolder">
            <div class="row-left">
              <span class="doc-name" data-rename-target="label"><%= folder_entry[:title] %></span>
            </div>
            <div class="row-right">
              <% if folder %>
                <button
                  type="button"
                  class="row-pencil"
                  aria-label="Edit folder"
                  data-action="click->rename#openModal"
                  data-rename-url="<%= rename_document_path(folder) %>"
                  data-delete-url="<%= document_path(folder) %>"
                  data-current-name="<%= folder.title %>"
                  data-doc-kind="folder"
                >✎</button>
              <% end %>
              <span class="doc-count"><%= files.size %> file<%= "s" if files.size != 1 %></span>
            </div>
          </div>

          <div class="folder-dropdown <%= open_folder ? 'is-open' : '' %>" data-recent-docs-target="folderDropdown">
            <div class="plc-header-row organizer-row" data-type="file-list" data-no-toggle="true">
              <div class="row-left">
                <span class="plc-header-label">Items</span>
                <% if folder %>
                    <button type="button"
                      class="btn btn-secondary btn-tiny action new-button"
                      data-action="click->recent-docs#openItemCreator"
                      data-folder-id="<%= folder.id %>"
                      data-create-url="<%= create_file_document_path(folder) %>">
                    New Item
                  </button>
                <% else %>
                  <span class="folder-toolbar-hint">Read-only folder</span>
                <% end %>
              </div>
              <div class="row-right"></div>
            </div>

            <%= render "folder_file_list", files: files %>
          </div>
        </li>
      <% end %>

      <% if @root_files.any? %>
        <li class="doc-row unfiled-header" aria-hidden="true">
          <div class="doc-link"><span class="doc-name">Unfiled Items</span></div>
        </li>
        <% @root_files.each do |doc| %>
          <% display_name = doc.title.presence || "Untitled" %>
          <li class="doc-row doc-row--file-inline" tabindex="0" data-recent-docs-target="doc" data-doc-kind="file" data-delete-url="<%= document_path(doc) %>">
            <div class="doc-link doc-link--static organizer-row file-row">
              <span class="row-left">
                <%= link_to(display_name.presence || "Untitled", document_path(doc), class: "file-link", data: { rename_target: "label" }) %>
              </span>
              <span class="row-right">
                <button
                  type="button"
                  class="row-pencil"
                  aria-label="Edit file"
                  data-action="click->rename#openModal"
                  data-rename-url="<%= rename_document_path(doc) %>"
                  data-delete-url="<%= document_path(doc) %>"
                  data-current-name="<%= display_name %>"
                  data-doc-kind="file"
                >✎</button>
              </span>
            </div>
          </li>
        <% end %>
      <% end %>
    </ul>

    <div class="rename-modal-backdrop hidden" data-rename-target="modalBackdrop" data-action="click->rename#clickBackdrop" aria-hidden="true">
      <div class="rename-modal" data-rename-target="modal" role="dialog" aria-modal="true" aria-labelledby="rename-modal-title">
        <h3 id="rename-modal-title" class="rename-modal-title" data-rename-target="modalTitle">Edit Item</h3>
        <input type="text" class="rename-modal-input" data-rename-target="modalInput" aria-label="Name">
        <div class="rename-modal-actions">
          <button type="button" class="btn btn-primary" data-rename-target="modalSave" data-action="click->rename#save">Save</button>
          <button type="button" class="btn btn-danger" data-rename-target="modalDelete" data-action="click->rename#remove">Delete</button>
          <button type="button" class="btn btn-secondary" data-action="click->rename#closeModal">Cancel</button>
        </div>
      </div>
    </div>

    <div class="item-create-modal-backdrop hidden" data-recent-docs-target="itemCreatorBackdrop" data-action="click->recent-docs#clickItemCreatorBackdrop" aria-hidden="true">
      <div class="item-create-modal" role="dialog" aria-modal="true" aria-labelledby="item-create-title">
        <h3 id="item-create-title" class="rename-modal-title">What would you like to create?</h3>
        <p class="folder-toolbar-hint">Choose a content type for this folder item.</p>
        <div class="rename-modal-actions">
          <button type="button" class="btn btn-primary" data-action="click->recent-docs#createNoteItem">Create Note</button>
          <button type="button" class="btn btn-secondary" data-action="click->recent-docs#createTaskListItem">Create Task List</button>
          <button type="button" class="btn btn-secondary" data-action="click->recent-docs#closeItemCreator">Cancel</button>
        </div>
      </div>
    </div>
  </section>
<% else %>
  <p class="empty-state">No folders or items yet. Create a folder to get started.</p>
<% end %>
