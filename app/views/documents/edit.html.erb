<div class="workspace note-workspace">
  <% if @document.content_type == "task_list" %>
    <%= form_with model: @document,
                  url: document_path(@document),
                  method: :patch,
                  class: "workspace-form task-list-form",
                  data: { controller: "task-list", task_list_debounce_value: 300 } do |f| %>
      <header class="workspace-header note-header">
        <div class="header-top">
          <div class="header-title-block">
            <%= f.text_field :title,
                             class: "workspace-title-input note-title-input",
                             placeholder: "Untitled Task List",
                             autocomplete: "off",
                             data: { task_list_target: "title", action: "input->task-list#queueSave" } %>
          </div>
          <div class="header-actions">
            <button type="button" class="btn btn-toolbar btn-toolbar-icon" data-action="click->task-list#toggleResetSettings" aria-label="Toggle reset settings">⏲</button>
            <button type="button" class="btn btn-toolbar btn-toolbar-icon" data-action="click->task-list#addTask" aria-label="Add row">+</button>
            <%= link_to "Back", root_path, class: "btn btn-toolbar" %>
          </div>
        </div>
        <p class="loaded-status" data-controller="clock">
          <span data-task-list-target="status">Saved</span>
          <span class="workspace-clock workspace-clock--toggle"
                data-clock-target="display"
                data-action="click->task-list#toggleResetSettings"
                role="button"
                tabindex="0"
                title="Toggle reset days"></span>
        </p>
      </header>

      <div class="task-reset-panel hidden" data-task-list-target="resetPanel">
        <p class="folder-toolbar-hint">Reset completed tasks at 7:00 AM on selected days.</p>
        <div class="reset-days-grid">
          <% %w[Sun Mon Tue Wed Thu Fri Sat].each_with_index do |label, index| %>
            <button type="button"
                    class="btn btn-secondary reset-day-button"
                    data-day-index="<%= index %>"
                    data-action="click->task-list#toggleResetDay"><%= label %></button>
          <% end %>
        </div>
      </div>

      <%= hidden_field_tag "document[tasks_payload]", @document.tasks.to_json, data: { task_list_target: "tasksPayload" } %>
      <%= hidden_field_tag "document[last_reset_at]", @document.last_reset_at&.iso8601, data: { task_list_target: "lastResetAt" } %>
      <% Array(@document.reset_days).each do |day| %>
        <%= hidden_field_tag "document[reset_days][]", day, data: { task_list_target: "resetDay" } %>
      <% end %>

      <div class="task-list-shell">
        <div class="task-list-rows" data-task-list-target="rows">
          <% Array(@document.tasks).each_with_index do |task, main_index| %>
            <% text = task.is_a?(Hash) ? task["text"].to_s : "" %>
            <% checked = task.is_a?(Hash) ? !!task["checked"] : false %>
            <% subtasks = task.is_a?(Hash) ? Array(task["subtasks"]) : [] %>
            <div class="organizer-row task-item-row task-item-row--main <%= 'task-item-group--head' if subtasks.any? %> <%= 'task-item-row--checked' if checked %>"
                 data-task-list-target="row"
                 data-main-index="<%= main_index %>"
                 data-action="click->task-list#toggleRow">
              <div class="row-left">
                <span class="task-item-text"><%= text.presence || "Untitled Task" %></span>
              </div>
              <div class="row-right">
                <button type="button" class="row-plus" data-action="click->task-list#addSubtask">+</button>
                <button type="button" class="row-pencil" data-action="click->task-list#editRow">✎</button>
              </div>
            </div>

            <% subtasks.each_with_index do |subtask, sub_index| %>
              <% subtask_text = subtask.is_a?(Hash) ? subtask["text"].to_s : "" %>
              <% subtask_checked = subtask.is_a?(Hash) ? !!subtask["checked"] : false %>
              <div class="organizer-row task-item-row task-item-row--subtask task-item-group--child <%= 'task-item-group--tail' if sub_index == subtasks.length - 1 %> <%= 'task-item-row--checked' if subtask_checked %>"
                   data-task-list-target="row"
                   data-main-index="<%= main_index %>"
                   data-sub-index="<%= sub_index %>"
                   data-action="click->task-list#toggleRow">
                <div class="row-left">
                  <span class="task-item-text task-item-text--subtask"><%= subtask_text.presence || "Untitled Subtask" %></span>
                </div>
                <div class="row-right">
                  <button type="button" class="row-pencil" data-action="click->task-list#editRow">✎</button>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="rename-modal-backdrop hidden" data-task-list-target="editModalBackdrop" data-action="click->task-list#clickEditModalBackdrop" aria-hidden="true">
        <div class="rename-modal task-edit-modal" role="dialog" aria-modal="true" aria-labelledby="task-edit-title">
          <h3 id="task-edit-title" class="rename-modal-title">Edit Task</h3>
          <input type="text" class="rename-modal-input" data-task-list-target="editInput" data-action="keydown.enter->task-list#saveTaskEdit" autocomplete="off">
          <div class="rename-modal-actions">
            <button type="button" class="btn btn-primary" data-action="click->task-list#saveTaskEdit">Save</button>
            <button type="button" class="btn btn-danger" data-action="click->task-list#deleteTask">Delete</button>
            <button type="button" class="btn btn-secondary" data-action="click->task-list#closeTaskEdit">Cancel</button>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <%= form_with model: @document, url: document_path(@document), method: :patch, class: "workspace-form note-form", data: { controller: "note-editor", note_editor_debounce_value: 400 } do |f| %>
      <header class="workspace-header note-header">
        <div class="header-top">
          <div class="header-title-block">
            <%= f.text_field :title,
                             class: "workspace-title-input note-title-input",
                             placeholder: "Untitled",
                             autocomplete: "off",
                             data: { note_editor_target: "title", action: "input->note-editor#onTitleInput blur->note-editor#flush" } %>
          </div>
          <div class="header-actions">
            <%= link_to "Back", root_path, class: "btn btn-toolbar" %>
          </div>
        </div>
        <p class="loaded-status" data-controller="clock">
          <span data-note-editor-target="status">Saved</span>
          <span class="workspace-clock" data-clock-target="display"></span>
        </p>
      </header>

      <%= f.hidden_field :content, data: { note_editor_target: "content" } %>
      <div class="note-editor-shell">
        <div class="note-editor"
             contenteditable="true"
             spellcheck="true"
             data-note-editor-target="editor"
              data-action="input->note-editor#onEditorInput blur->note-editor#flush paste->note-editor#onPaste"
             role="textbox"
             aria-multiline="true"
             aria-label="Note content"></div>
      </div>
    <% end %>
  <% end %>
</div>
