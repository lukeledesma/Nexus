      <section class="content-window os-window is-hidden"
        data-controller="content-window"
        data-content-window-app-key-value="theme-studio"
        data-content-window-app-url-value="/apps/theme_studio"
        data-content-window-storage-key-value="nexus.contentWindow.themeStudio.bounds"
        data-content-window-frame-id-value="theme-studio-pane"
        aria-live="polite">
        <header class="content-window-chrome theme-studio-window-chrome">
          <div class="theme-studio-window-title-shell">
            <h2 class="content-window-chrome-title">THEME STUDIO</h2>
            <span class="theme-studio-window-title-separator" aria-hidden="true">|</span>
            <span class="theme-studio-window-title-subtext" data-theme-studio-chrome="status">Default</span>
            <input
              type="text"
              class="settings-themes-item-rename-input theme-builder-name-input theme-builder-hidden theme-studio-window-title-input"
              data-theme-studio-chrome="name-input"
              placeholder="Theme..."
              autocomplete="off"
              spellcheck="false"
              maxlength="64"
              aria-label="Theme name"
            >
            <button
              type="button"
              class="settings-themes-item-action-btn settings-themes-item-rename-btn theme-builder-save-btn theme-builder-hidden theme-studio-window-title-save"
