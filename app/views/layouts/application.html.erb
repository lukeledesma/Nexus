<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "NEXUS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="NEXUS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="shortcut icon" href="/favicon-32.png?v=2" type="image/png">
    <link rel="icon" href="/favicon-32.png?v=2" sizes="32x32" type="image/png">
    <link rel="icon" href="/favicon.png?v=2" type="image/png">
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= logged_in? ? "nexus-os" : "" %>" data-controller="window-manager">
    <% if logged_in? %>
      <div id="desktop" class="desktop-layer"></div>

      <div class="desktop-clock" data-controller="desktop-clock">
        <span class="desktop-clock-display" data-desktop-clock-target="display"></span>
      </div>

      <section id="organizer-window" class="os-window organizer-window is-hidden" aria-live="polite">
        <div class="window-content">
          <%= render "organizer/sidebar" %>
        </div>
      </section>

      <section class="content-window os-window is-hidden" data-controller="content-window" aria-live="polite">
        <div class="title-bar" data-action="mousedown->content-window#startDrag touchstart->content-window#startDrag"></div>
        <button type="button" class="tools-close-btn content-window-close" data-action="click->content-window#close" aria-label="Close" title="Close">✕</button>
        <div class="pane-resize-handle pane-resize-handle--top" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--right" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--bottom" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--left" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--top-left" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--top-right" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--bottom-left" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="pane-resize-handle pane-resize-handle--bottom-right" data-action="mousedown->content-window#startResize touchstart->content-window#startResize"></div>
        <div class="window-content">
          <turbo-frame id="app-pane" class="finder-app-frame"></turbo-frame>
        </div>
      </section>

      <section class="db-health-window os-window is-hidden" data-controller="db-health" data-db-health-url-value="<%= db_health_path %>" data-db-health-target="window" aria-live="polite">
          <section class="db-health-panel" data-db-health-target="panel">
          <header class="db-health-header" data-action="mousedown->db-health#startDrag touchstart->db-health#startDrag">
            <div class="db-health-title-wrap">
              <h3 data-db-health-target="title">DB Health</h3>
              <span class="db-health-heartbeat" aria-hidden="true">♥</span>
            </div>
            <div class="db-health-controls">
              <button type="button" class="db-health-back hidden" data-db-health-target="backButton" data-action="click->db-health#clearFocus" aria-label="Back" title="Back">←</button>
              <button type="button" class="db-health-refresh" data-action="click->db-health#refresh" aria-label="Refresh" title="Refresh">↻</button>
              <button type="button" class="db-health-close" data-action="click->db-health#close" aria-label="Close" title="Close">✕</button>
            </div>
          </header>

          <p class="db-health-stamp" data-db-health-target="stamp">Waiting for data...</p>

          <dl class="db-health-grid" data-db-health-target="grid">
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="folders" data-action="click->db-health#focusMetric"><dt>Folders</dt><dd data-db-health-target="foldersCount">-</dd></div>
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="items" data-action="click->db-health#focusMetric"><dt>Items</dt><dd data-db-health-target="itemsCount">-</dd></div>
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="item_id_total" data-action="click->db-health#focusMetric"><dt>Item IDs</dt><dd data-db-health-target="maxItemId">-</dd></div>
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="workspace" data-action="click->db-health#focusMetric"><dt>Workspace Size</dt><dd data-db-health-target="workspaceSize">-</dd></div>
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="users" data-action="click->db-health#focusMetric"><dt>Users</dt><dd data-db-health-target="usersCount">-</dd></div>
            <div class="db-health-card db-health-card--selectable" data-db-health-target="metricCard" data-db-health-focus-key="db_size" data-action="click->db-health#focusMetric"><dt>DB Size</dt><dd data-db-health-target="dbSize">-</dd></div>
          </dl>

          <section class="db-health-detail hidden" data-db-health-target="detailWrap">
            <h4 data-db-health-target="detailTitle">Details</h4>
            <ul class="db-health-detail-list" data-db-health-target="detailList"></ul>
          </section>
          </section>
      </section>

      <section class="settings-window os-window is-hidden" data-controller="settings" data-settings-target="window" aria-live="polite">
        <section class="settings-panel">
          <header class="settings-header" data-action="mousedown->settings#startDrag touchstart->settings#startDrag">
            <h3>Settings</h3>
            <div class="settings-controls">
              <button type="button" class="settings-close" data-action="click->settings#close" aria-label="Close Settings" title="Close">✕</button>
            </div>
          </header>

          <p class="settings-stamp"><%= current_user&.email.presence || "Unknown user" %></p>

          <div class="settings-actions">
            <%= button_to logout_path, method: :delete, class: "settings-action settings-action--logout" do %>
              <div class="organizer-tool-card">
                <dt class="organizer-tool-label">LOGOUT</dt>
                <dd class="organizer-tool-value">EXIT</dd>
              </div>
            <% end %>
          </div>
        </section>
      </section>

      <section class="stationary-window os-window is-hidden" data-controller="stationary" data-stationary-target="window" aria-live="polite">
        <section class="stationary-panel">
          <header class="stationary-header" data-action="mousedown->stationary#startDrag touchstart->stationary#startDrag">
            <h3>Stationary</h3>
            <div class="stationary-controls">
              <button type="button" class="stationary-close" data-action="click->stationary#close" aria-label="Close Stationary" title="Close">✕</button>
            </div>
          </header>
          <p class="stationary-stamp" data-stationary-target="stamp">—</p>
          <div class="stationary-grid">
            <button type="button" class="stationary-card-btn" data-app-url="/apps/singular_note" data-action="click->stationary#launchApp">
              <div class="organizer-tool-card">
                <dt class="organizer-tool-label">NOTES</dt>
                <dd class="organizer-tool-value" data-stationary-target="notesSize">-</dd>
              </div>
            </button>
            <button type="button" class="stationary-card-btn" data-app-url="/apps/singular_task_list" data-action="click->stationary#launchApp">
              <div class="organizer-tool-card">
                <dt class="organizer-tool-label">TASKS</dt>
                <dd class="organizer-tool-value" data-stationary-target="tasksSize">-</dd>
              </div>
            </button>
          </div>
        </section>
      </section>
    <% end %>

    <%= yield %>
  </body>
</html>
