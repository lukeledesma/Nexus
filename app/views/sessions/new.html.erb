<% content_for :title, "Login" %>

<main class="login-container">
  <div class="login-form-wrapper">
    <h1 class="app-title">NEXUS</h1>
    <p class="login-subtitle">Sign in to your workspace</p>

    <% if @login_error.present? || flash[:alert].present? %>
      <p class="login-error"><%= @login_error.presence || flash[:alert] %></p>
    <% end %>

    <%= form_with url: login_path, method: :post, local: true, data: { turbo: false }, class: "login-form" do %>
      <div class="form-group">
        <%= text_field_tag :identifier, @identifier.presence || params[:identifier], required: true, autofocus: true, autocomplete: "username", placeholder: "Email or username", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= password_field_tag :password, nil, required: true, autocomplete: "current-password", placeholder: "Password", class: "form-input" %>
      </div>

      <%= submit_tag "Sign In", class: "btn btn-primary btn-block" %>
    <% end %>
  </div>
</main>